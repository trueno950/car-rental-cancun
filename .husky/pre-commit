#!/usr/bin/env sh

pnpm exec lint-staged || exit $?

if ! command -v gga >/dev/null 2>&1; then
  printf '%s\n' 'Skipping GGA: CLI not installed. Install it locally before expecting AI review enforcement.' >&2
  exit 0
fi

resolve_gga_provider() {
  if [ -n "${GGA_PROVIDER:-}" ]; then
    printf '%s' "$GGA_PROVIDER"
    return 0
  fi

  if command -v opencode >/dev/null 2>&1; then
    printf '%s' 'opencode'
    return 0
  fi

  if command -v codex >/dev/null 2>&1; then
    printf '%s' 'codex'
    return 0
  fi

  if command -v claude >/dev/null 2>&1; then
    printf '%s' 'claude'
    return 0
  fi

  if command -v gemini >/dev/null 2>&1; then
    printf '%s' 'gemini'
    return 0
  fi

  if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
    printf '%s' 'github:gpt-4o'
    return 0
  fi

  return 1
}

provider="$(resolve_gga_provider)"

if [ -z "$provider" ]; then
  printf '%s\n' 'Skipping GGA: no supported provider is configured. Set GGA_PROVIDER or authenticate a supported local CLI.' >&2
  exit 0
fi

# gga v2.8.1 reviews staged files by default; there is no separate --staged flag.
GGA_PROVIDER="$provider" GGA_TIMEOUT="${GGA_TIMEOUT:-90}" gga run
